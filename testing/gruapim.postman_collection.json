{
  "info": {
    "name": "GRUAPIM — Suite completa (gateway)",
    "description": "Fluxo end-to-end da plataforma GRUAPIM através do API Gateway. Cobre autenticação, usuários, projetos, membros, user stories, sprints, kanban, tasks, git, burndown e o microsserviço de colaboração (notificações, atas e histórico de chat). Os requests são encadeados por variáveis e devem ser executados em ordem (Newman roda assim por padrão).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8090" },
    { "key": "aliceName", "value": "Alice Scrum" },
    { "key": "aliceEmail", "value": "alice@gruapim.dev" },
    { "key": "alicePassword", "value": "alice12345" },
    { "key": "bobName", "value": "Bob Dev" },
    { "key": "bobEmail", "value": "bob@gruapim.dev" },
    { "key": "bobPassword", "value": "bob12345" }
  ],
  "item": [
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "Registrar Alice (Scrum Master)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('registro aceito ou já existente', function () {",
            "  pm.expect([201, 400]).to.include(pm.response.code);",
            "});"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{aliceName}}\",\n  \"email\": \"{{aliceEmail}}\",\n  \"password\": \"{{alicePassword}}\",\n  \"role\": \"SCRUM_MASTER\"\n}" }
          }
        },
        {
          "name": "Login Alice",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('retorna token', () => pm.expect(j.token).to.be.a('string'));",
            "pm.collectionVariables.set('aliceToken', j.token);",
            "pm.collectionVariables.set('aliceId', j.userId);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{aliceEmail}}\",\n  \"password\": \"{{alicePassword}}\"\n}" }
          }
        },
        {
          "name": "Registrar Bob (Developer)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('registro aceito ou já existente', function () {",
            "  pm.expect([201, 400]).to.include(pm.response.code);",
            "});"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{bobName}}\",\n  \"email\": \"{{bobEmail}}\",\n  \"password\": \"{{bobPassword}}\",\n  \"role\": \"DEVELOPER\"\n}" }
          }
        },
        {
          "name": "Login Bob",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('bobToken', j.token);",
            "pm.collectionVariables.set('bobId', j.userId);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{bobEmail}}\",\n  \"password\": \"{{bobPassword}}\"\n}" }
          }
        }
      ]
    },
